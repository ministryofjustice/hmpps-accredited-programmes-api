<h1 class="title">Accredited programmes</h1>
<h2>Referrals</h2>
    {{#referrals}}
        <h3>Referral {{ optionalValue (getIndexPlusOne @index) }}</h3>
        <br>
        <table class="data-table">
            <tr>
                <td class="data-column-33">Prisoner number</td>
                <td class="data-column-33">Status</td>
                <td class="data-column-33">Submitted on</td>
            </tr>
            <tr>
                <td>{{ optionalValue prisonerNumber }}</td>
                <td>{{ optionalValue statusCode }}</td>
                <td>{{ optionalValue (formatDate submittedOn) }}</td>
            </tr>
        </table>
        <table class="data-table">
            <tr>
                <td class="data-column-33">Referrer</td>
                <td class="data-column-33">OASys confirmed</td>
                <td class="data-column-33">Has reviewed programme history</td>
            </tr>
            <tr>
                <td>{{ getUserLastName referrerUsername}}</td>
                <td>{{ convertBoolean oasysConfirmed }}</td>
                <td>{{ convertBoolean hasReviewedProgrammeHistory }}</td>
            </tr>
        </table>
        <table class="data-table">
            <tr>
                <td class="data-column-33">Primary POM staff ID</td>
                <td class="data-column-33">Secondary POM staff ID</td>
                <td class="data-column-33">Original referral ID</td>
            </tr>
            <tr>
                <td>{{ optionalValue primaryPomStaffId }}</td>
                <td>{{ optionalValue secondaryPomStaffId }}</td>
                <td>{{ optionalValue originalReferralId }}</td>
            </tr>
        </table>
        <table class="data-table">
            <tr>
                <td class="data-column-33">Has LDC</td>
                <td class="data-column-33">Has LDC been overridden by programme team</td>
                <td class="data-column-33">Has reviewed additional information</td>
            </tr>
            <tr>
                <td>{{ convertBoolean hasLdc }}</td>
                <td>{{ convertBoolean hasLdcBeenOverriddenByProgrammeTeam }}</td>
                <td>{{ convertBoolean hasReviewedAdditionalInformation }}</td>
            </tr>
        </table>
        <table class="data-table">
            <tr>
                <td class="data-column-33">Referrer override reason</td>
                <td class="data-column-33">Deleted</td>
                <td class="data-column-33"></td>
            </tr>
            <tr>
                <td>{{ optionalValue referrerOverrideReason }}</td>
                <td>{{ convertBoolean deleted }}</td>
                <td></td>
            </tr>
        </table>
        <table class="data-table">
            <tr>
                <td class="data-column-100">Additional information</td>
            </tr>
            <tr>
                <td>{{ optionalValue additionalInformation }}</td>
            </tr>
        </table>
        <br>
    {{/referrals}}
    {{^referrals}}
        <p>No Data Held</p>
    {{/referrals}}

    <h2>Course participation</h2>
    {{#courseParticipation}}
        <h3>Course {{ optionalValue (getIndexPlusOne @index) }}</h3>
        <br>
        <table class="data-table">
            <tr>
                <td class="data-column-33">Prisoner number</td>
                <td class="data-column-33">Course name</td>
                <td class="data-column-33">Created date-time</td>
            </tr>
            <tr>
                <td>{{ optionalValue prisonNumber }}</td>
                <td>{{ optionalValue courseName }}</td>
                <td>{{ optionalValue (formatDate createdDateTime) }}</td>
            </tr>
        </table>
        <table class="data-table">
            <tr>
                <td class="data-column-33">Is draft</td>
                <td class="data-column-33">Other course name</td>
                <td class="data-column-33">Outcome detail</td>
            </tr>
            <tr>
                <td>{{ convertBoolean isDraft }}</td>
                <td>{{ optionalValue otherCourseName }}</td>
                <td>{{ optionalValue outcomeDetail }}</td>
            </tr>
        </table>
        <table class="data-table">
            <tr>
                <td class="data-column-100">Created by</td>
            </tr>
            <tr>
                <td>{{ getUserLastName createdByUser}}</td>
            </tr>
        </table>
        <table class="data-table">
            <tr>
                <td class="data-column-33">Source</td>
                <td class="data-column-33">Type</td>
                <td class="data-column-33">Outcome</td>
            </tr>
            <tr>
                <td>{{ optionalValue source }}</td>
                <td>{{ optionalValue type}}</td>
                <td>{{ optionalValue outcomeStatus }}</td>
            </tr>
        </table>
        <table class="data-table">
            <tr>
                <td class="data-column-33">Year started</td>
                <td class="data-column-33">Year completed</td>
                <td class="data-column-33">Location</td>
            </tr>
            <tr>
                <td>{{ optionalValue yearStarted }}</td>
                <td>{{ optionalValue yearCompleted}}</td>
                <td>{{ getPrisonName location }}</td>
            </tr>
        </table>
        <table class="data-table">
            <tr>
                <td class="data-column-33">Updated by</td>
                <td class="data-column-33">Updated date-time</td>
                <td class="data-column-33"></td>
            </tr>
            <tr>
                <td>{{ getUserLastName updatedByUser}}</td>
                <td>{{ optionalValue (formatDate updatedDateTime) }}</td>
                <td></td>
            </tr>
        </table>
        <table class="data-table">
            <tr>
                <td class="data-column-100">Detail</td>
            </tr>
            <tr>
                <td>{{ optionalValue detail }}</td>
            </tr>
        </table>
        <br>
    <br>
    {{/courseParticipation}}
    {{^courseParticipation}}
        <p>No Data Held</p>
    {{/courseParticipation}}

