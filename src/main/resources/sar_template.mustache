            <tr>
                <td class="data-column-33">Person ID</td>
                <td class="data-column-33">Prison number</td>
                <td class="data-column-33">Forename</td>
            </tr>
            <tr>
                <td>{{ optionalValue id }}</td>
                <td>{{ optionalValue prisonNumber }}</td>
                <td>{{ optionalValue forename }}</td>
            </tr>
        </table>
        <table class="data-table">
            <tr>
                <td class="data-column-33">Surname</td>
                <td class="data-column-33">Location</td>
                <td class="data-column-33">Gender</td>
            </tr>
            <tr>
                <td>{{ optionalValue surname }}</td>
                <td>{{ optionalValue location }}</td>
                <td>{{ optionalValue gender }}</td>
            </tr>
        </table>
        <table class="data-table">
            <tr>
                <td class="data-column-33">Conditional release date</td>
                <td class="data-column-33">Parole eligibility date</td>
                <td class="data-column-33">Tariff expiry date</td>
            </tr>
            <tr>
                <td>{{ optionalValue conditionalReleaseDate }}</td>
                <td>{{ optionalValue paroleEligibilityDate }}</td>
                <td>{{ optionalValue tariffExpiryDate }}</td>
            </tr>
        </table>
        <table class="data-table">
            <tr>
                <td class="data-column-33">Earliest release date</td>
                <td class="data-column-33">Earliest release date type</td>
                <td class="data-column-33">Sentence type</td>
            </tr>
            <tr>
                <td>{{ optionalValue earliestReleaseDate }}</td>
                <td>{{ optionalValue earliestReleaseDateType }}</td>
                <td>{{ optionalValue sentenceType }}</td>
            </tr>
        </table>
        <table class="data-table">
            <tr>
                <td class="data-column-33">Indeterminate sentence</td>
                <td class="data-column-33">Non DTO release date type</td>
                <td class="data-column-33"></td>
            </tr>
            <tr>
                <td>{{ convertBoolean indeterminateSentence }}</td>
                <td>{{ optionalValue nonDtoReleaseDateType }}</td>
                <td></td>
            </tr>
        </table>
    {{/person}}
    {{^person}}
        <p>No Data Held</p>
    {{/person}}

