        <table class="summary-list">
            <tr><td>ID</td><td>{{ optionalValue id }}</td></tr>
            <tr><td>Category</td><td>{{ optionalValue category }}</td></tr>
            <tr><td>Score</td><td>{{ optionalValue score }}</td></tr>
