    <h2>PNI results</h2>
    {{#pniResults}}
        <h3>PNI result {{ optionalValue (getIndexPlusOne @index) }}</h3>
        <br>
        <table class="data-table">
            <tr>
                <td class="data-column-33">Prisoner number</td>
                <td class="data-column-33">CRN</td>
                <td class="data-column-33">Programme pathway</td>
            </tr>
            <tr>
                <td>{{ optionalValue prisonNumber }}</td>
                <td>{{ optionalValue crn }}</td>
                <td>{{ optionalValue programmePathway }}</td>
            </tr>
        </table>
        <table class="data-table">
            <tr>
                <td class="data-column-33">Needs classification</td>
                <td class="data-column-33">Overall needs score</td>
                <td class="data-column-33">Risk classification</td>
            </tr>
            <tr>
                <td>{{ optionalValue needsClassification }}</td>
                <td>{{ optionalValue overallNeedsScore }}</td>
                <td>{{ optionalValue riskClassification }}</td>
            </tr>
        </table>
        <table class="data-table">
            <tr>
                <td class="data-column-33">OASys assessment completed date</td>
                <td class="data-column-33">PNI assessment date</td>
                <td class="data-column-33">PNI valid</td>
            </tr>
            <tr>
                <td>{{ optionalValue (formatDate oasysAssessmentCompletedDate) }}</td>
                <td>{{ optionalValue (formatDate pniAssessmentDate) }}</td>
                <td>{{ convertBoolean pniValid }}</td>
            </tr>
        </table>
        <table class="data-table">
            <tr>
                <td class="data-column-33">Basic skills score</td>
                <td class="data-column-33"></td>
                <td class="data-column-33"></td>
            </tr>
            <tr>
                <td>{{ optionalValue basicSkillsScore }}</td>
                <td></td>
                <td></td>
            </tr>
        </table>
        <table class="data-table">
            <tr>
                <td class="data-column-100">PNI result JSON</td>
            </tr>
            <tr>
                <td>{{ optionalValue pniResultJson }}</td>
            </tr>
        </table>
        <br>
    {{/pniResults}}
    {{^pniResults}}
        <p>No Data Held</p>
    {{/pniResults}}

    <h2>Person</h2>
    {{#person}}
